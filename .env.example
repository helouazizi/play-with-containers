# .env file example
# This file contains environment variables for configuring the microservices.
# It should be copied to a file named '.env' in the project root and filled with actual values.
# The '.env' file is ignored by Git to prevent sensitive information from being committed.

# PostgreSQL Credentials for Inventory Database
POSTGRES_USER_INVENTORY=inventoryuser
POSTGRES_PASSWORD_INVENTORY=inventorypassword
POSTGRES_DB_INVENTORY=inventorydb

# PostgreSQL Credentials for Billing Database
POSTGRES_USER_BILLING=billinguser
POSTGRES_PASSWORD_BILLING=billingpassword
POSTGRES_DB_BILLING=billingdb

# RabbitMQ Credentials
RABBITMQ_DEFAULT_USER=rabbitmquser
RABBITMQ_DEFAULT_PASS=rabbitmqpassword
RABBITMQ_DEFAULT_VHOST=/
RABBITMQ_QUEUE=billing_queue
RABBITMQ_PORT=5672

# Application Ports (exposed to host for API Gateway, internal for others)
INVENTORY_PORT=8080
BILLING_PORT=8080
API_GATEWAY_PORT=3000

# Internal Docker service names (used by API Gateway for routing and inter-service communication)
API_GATEWAY_HOST=api-gateway-app
INVENTORY_APP_HOST=inventory-app
BILLING_APP_HOST=billing-app
INVENTORY_DB_HOST=inventory-db
INVENTORY_DB_PORT=5432
BILLING_DB_HOST=billing-db
BILLING_DB_PORT=5432
RABBITMQ_HOST=rabbit-queue